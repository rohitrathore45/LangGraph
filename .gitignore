# ------------------------------
venv/
.env/
.env.*

# ------------------------------
# Environment variables
# ------------------------------
.env
.env.local
.env.*.local

# ------------------------------
# Jupyter Notebook checkpoints
# ------------------------------
.ipynb_checkpoints/

# ------------------------------
# VS Code settings
# ------------------------------
.vscode/

# ------------------------------
# Logs & temp files
# ------------------------------
*.log
*.tmp
*.temp

# ------------------------------
# OS files
# ------------------------------
.DS_Store
Thumbs.db

# ------------------------------
# Python build files
# ------------------------------
build/
dist/
*.egg-info/

# ------------------------------
